Host raspi raspi.local
  IdentityFile ~/.ssh/raspberrypi.pub
  IdentitiesOnly yes

Host gitea.greedo.net
  Port 222
  IdentityFile ~/.ssh/gitea.pub
  IdentitiesOnly yes

Host truenas.local
  HostName truenas.local
  User bvdwalt
  SetEnv TERM=xterm-256color

Host jump-k8s-dev
  HostName {{ output "sops" "-d" "--extract" "[\"dev_hostname\"]" (printf "%s/../secrets/jump-hosts.sops.yaml" .chezmoi.sourceDir) | trim }}
  User jumpuser
  IdentityFile ~/.ssh/jumpserver-ssh.pub
  IdentitiesOnly yes

Host jump-k8s-prd
  HostName {{ output "sops" "-d" "--extract" "[\"prd_hostname\"]" (printf "%s/../secrets/jump-hosts.sops.yaml" .chezmoi.sourceDir) | trim }}
  User jumpuser
  IdentityFile ~/.ssh/jumpserver-ssh.pub
  IdentitiesOnly yes

Host *
{{- if eq .chezmoi.os "darwin" }}
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
{{- if eq .chezmoi.os "linux" }}
  IdentityAgent ~/.1password/agent.sock
{{- end }}

