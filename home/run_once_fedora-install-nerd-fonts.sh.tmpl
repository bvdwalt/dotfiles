{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "fedora") -}}
#!/bin/bash
# Downloads and installs FiraCode Nerd Font for the current user.
# Uses run_once so it only runs a single time (tracked by chezmoi state).
# Update the version below to re-trigger the install on next `chezmoi apply`.
# NERD_FONTS_VERSION: v3.2.1

set -euo pipefail

NERD_FONTS_VERSION="v3.2.1"
FONT_DIR="$HOME/.local/share/fonts/NerdFonts"

if ls "$FONT_DIR"/FiraCodeNerdFont*.ttf &>/dev/null 2>&1; then
  echo "FiraCode Nerd Font already installed, skipping"
  exit 0
fi

echo "Installing FiraCode Nerd Font ${NERD_FONTS_VERSION}"

if ! command -v curl &>/dev/null; then
  echo "curl not found; cannot download fonts" >&2
  exit 1
fi

mkdir -p "$FONT_DIR"
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

curl -fsSL \
  "https://github.com/ryanoasis/nerd-fonts/releases/download/${NERD_FONTS_VERSION}/FiraCode.zip" \
  -o "$tmp/FiraCode.zip"

unzip -q "$tmp/FiraCode.zip" -d "$FONT_DIR"

# Refresh font cache so apps pick up the new font immediately
fc-cache -f "$FONT_DIR"

echo "FiraCode Nerd Font installed to $FONT_DIR"
{{ end -}}
